---
import { Image } from 'astro:assets';
import { formatDate, isoDate } from '../lib/utils';

interface Props {
  href: string;
  title: string;
  description: string;
  category: string;
  pubDate: Date;
  location?: string;
  caseStatus?: string;
  readingTime?: number;
  cover?: ImageMetadata;
  coverAlt?: string;
  featured?: boolean;
}

const {
  href,
  title,
  description,
  category,
  pubDate,
  location,
  caseStatus,
  readingTime,
  cover,
  coverAlt,
  featured = false,
} = Astro.props;
---

<article class:list={['card', { 'card--featured': featured }]}>
  <a href={href} class="card__link" aria-label={title}>
    {cover && (
      <div class="card__media">
        <Image
          src={cover}
          alt={coverAlt ?? ''}
          widths={[400, 800, 1200]}
          sizes={featured ? '(max-width: 800px) 100vw, 800px' : '(max-width: 600px) 100vw, 400px'}
          loading="lazy"
          class="card__img"
        />
      </div>
    )}
    <div class="card__body">
      <div class="card__meta">
        <span class="kicker">{category}</span>
        {caseStatus && <span class={`status status--${caseStatus.toLowerCase()}`}>{caseStatus}</span>}
      </div>
      <h3 class="card__title">{title}</h3>
      <p class="card__desc">{description}</p>
      <div class="card__foot">
        <time datetime={isoDate(pubDate)}>{formatDate(pubDate)}</time>
        {location && <span class="card__dot">·</span>}
        {location && <span>{location}</span>}
        {readingTime && <span class="card__dot">·</span>}
        {readingTime && <span>{readingTime} min read</span>}
      </div>
    </div>
  </a>
</article>

<style>
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color 0.18s ease, transform 0.18s ease;
  }
  .card:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }
  .card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }
  .card__link:hover { color: inherit; }
  .card__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--surface-2);
  }
  .card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.85) contrast(1.05);
  }
  .card__body {
    padding: 1.25rem 1.35rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    flex: 1;
  }
  .card__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .card__title {
    font-size: 1.3rem;
    line-height: 1.2;
  }
  .card--featured .card__title {
    font-size: clamp(1.5rem, 1.2rem + 1.5vw, 2.1rem);
  }
  .card__desc {
    color: var(--text-muted);
    font-size: 0.96rem;
    line-height: 1.6;
  }
  .card__foot {
    margin-top: auto;
    padding-top: 0.4rem;
    color: var(--text-faint);
    font-size: 0.82rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
  }
  .card__dot { opacity: 0.6; }

  .status {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
    border-radius: 100px;
    border: 1px solid var(--border-strong);
    color: var(--text-muted);
  }
  .status--unsolved,
  .status--cold { color: var(--sepia); border-color: color-mix(in srgb, var(--sepia) 45%, transparent); }
  .status--solved { color: #7bdca0; border-color: rgba(123, 220, 160, 0.4); }
  .status--ongoing { color: var(--accent-hover); border-color: color-mix(in srgb, var(--accent) 50%, transparent); }

  .card--featured {
    grid-column: 1 / -1;
  }
  @media (min-width: 720px) {
    .card--featured .card__link {
      flex-direction: row;
    }
    .card--featured .card__media {
      flex: 1 1 55%;
      aspect-ratio: auto;
    }
    .card--featured .card__body {
      flex: 1 1 45%;
      justify-content: center;
      padding: 2rem;
    }
  }
</style>
