---
import { Image } from 'astro:assets';
import Badge from './Badge.astro';
import { formatDate, isoDate } from '../lib/utils';

/**
 * <FeaturedHero /> — the marquee case on the homepage. Large editorial treatment
 * with an image (or moody fallback), category, status, title, and summary.
 */
interface Props {
  href: string;
  title: string;
  summary: string;
  category: string;
  status?: string;
  pubDate: Date;
  location?: string;
  readingTime?: number;
  cover?: ImageMetadata;
  coverAlt?: string;
}
const { href, title, summary, category, status, pubDate, location, readingTime, cover, coverAlt } =
  Astro.props;
---

<article class="fhero">
  <a href={href} class="fhero__link" aria-label={title}>
    <div class="fhero__media">
      {cover ? (
        <Image src={cover} alt={coverAlt ?? ''} widths={[600, 1000, 1600]} sizes="(max-width: 900px) 100vw, 60vw" loading="eager" class="fhero__img" />
      ) : (
        <div class="fhero__placeholder" aria-hidden="true"><span>CASE FILE</span></div>
      )}
      <div class="fhero__scrim"></div>
    </div>
    <div class="fhero__body">
      <div class="fhero__badges">
        <Badge label="Featured Case" variant="accent" />
        <Badge label={category} variant="category" />
        {status && <Badge label={status} variant="status" status={status} />}
      </div>
      <h2 class="fhero__title">{title}</h2>
      <p class="fhero__summary">{summary}</p>
      <div class="fhero__meta">
        <time datetime={isoDate(pubDate)}>{formatDate(pubDate)}</time>
        {location && <><span class="dot">·</span><span>{location}</span></>}
        {readingTime && <><span class="dot">·</span><span>{readingTime} min read</span></>}
      </div>
      <span class="fhero__cta">Read the case <span aria-hidden="true">→</span></span>
    </div>
  </a>
</article>

<style>
  .fhero {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--surface);
  }
  .fhero__link {
    display: grid;
    grid-template-columns: 1fr;
    text-decoration: none;
    color: inherit;
  }
  .fhero__link:hover { color: inherit; }

  .fhero__media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--surface-2);
  }
  .fhero__img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: saturate(0.82) contrast(1.06) brightness(0.9);
    transition: transform 0.5s ease;
  }
  .fhero:hover .fhero__img { transform: scale(1.03); }
  .fhero__placeholder {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    background:
      repeating-linear-gradient(135deg, rgba(255,255,255,0.012) 0 2px, transparent 2px 10px),
      radial-gradient(120% 120% at 30% 0%, #1d1d23 0%, #0f0f12 70%);
  }
  .fhero__placeholder span {
    font-family: var(--font-mono);
    letter-spacing: 0.4em;
    color: var(--text-faint);
    font-size: 1.1rem;
  }
  .fhero__scrim {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(8,8,10,0.65), transparent 50%);
  }

  .fhero__body {
    padding: clamp(1.5rem, 3vw, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .fhero__badges { display: flex; gap: 0.45rem; flex-wrap: wrap; }
  .fhero__title {
    font-size: clamp(1.8rem, 1.3rem + 2.4vw, 3rem);
    line-height: 1.1;
  }
  .fhero__summary {
    color: var(--text-muted);
    font-size: clamp(1rem, 0.96rem + 0.3vw, 1.2rem);
    max-width: 60ch;
  }
  .fhero__meta {
    display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center;
    color: var(--text-faint); font-size: 0.85rem;
  }
  .dot { opacity: 0.5; }
  .fhero__cta {
    margin-top: 0.3rem;
    font-weight: 700;
    color: var(--accent-hover);
    letter-spacing: 0.02em;
  }

  @media (min-width: 900px) {
    .fhero__link { grid-template-columns: 1.15fr 1fr; }
    .fhero__media { aspect-ratio: auto; height: 100%; min-height: 420px; }
    .fhero__body { justify-content: center; }
  }
</style>
