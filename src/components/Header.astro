---
import { SITE, CATEGORIES } from '../site.config';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');

const utility = [
  { label: 'Home', href: '/' },
  { label: 'Cases', href: '/cases' },
  { label: 'About', href: '/about' },
  { label: 'Submit a Case', href: '/submit' },
];
---

<header class="site-header">
  <input type="checkbox" id="nav-toggle" class="nav-toggle" hidden />

  <div class="bar">
    <div class="container bar__inner">
      <a href="/" class="brand" aria-label={`${SITE.name} — home`}>
        <span class="brand__mark" aria-hidden="true">⌖</span>
        <span class="brand__name">{SITE.name}</span>
      </a>

      <nav class="util-nav" aria-label="Primary">
        {utility.map((i) => (
          <a href={i.href} class:list={['util-nav__link', { 'is-active': isActive(i.href) }]} aria-current={isActive(i.href) ? 'page' : undefined}>
            {i.label}
          </a>
        ))}
      </nav>

      <label for="nav-toggle" class="hamburger" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </label>
    </div>
  </div>

  <div class="catbar">
    <div class="container catbar__inner">
      <span class="catbar__label" aria-hidden="true">Case Files</span>
      <nav aria-label="Categories" class="catbar__nav">
        {CATEGORIES.map((c) => (
          <a href={`/${c.slug}`} class:list={['catbar__link', { 'is-active': isActive(`/${c.slug}`) }]} aria-current={isActive(`/${c.slug}`) ? 'page' : undefined}>
            {c.title}
          </a>
        ))}
      </nav>
    </div>
  </div>

  <nav class="mobile-panel" aria-label="Mobile">
    <div class="container">
      {utility.slice(0, 2).map((i) => (
        <a href={i.href} class:list={['mobile-panel__link', { 'is-active': isActive(i.href) }]}>{i.label}</a>
      ))}
      <span class="mobile-panel__heading">Case Files</span>
      {CATEGORIES.map((c) => (
        <a href={`/${c.slug}`} class:list={['mobile-panel__link', { 'is-active': isActive(`/${c.slug}`) }]}>{c.title}</a>
      ))}
      {utility.slice(2).map((i) => (
        <a href={i.href} class:list={['mobile-panel__link', { 'is-active': isActive(i.href) }]}>{i.label}</a>
      ))}
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(11, 11, 13, 0.9);
    backdrop-filter: saturate(140%) blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    min-height: 62px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    color: var(--text);
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.22rem;
    letter-spacing: -0.01em;
  }
  .brand:hover { color: var(--text); }
  .brand__mark { color: var(--accent); font-size: 1.2rem; }

  .util-nav { display: flex; align-items: center; gap: 0.25rem; }
  .util-nav__link {
    padding: 0.45rem 0.75rem;
    border-radius: var(--radius);
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text-muted);
    text-decoration: none;
  }
  .util-nav__link:hover { color: var(--text); background: var(--surface); }
  .util-nav__link.is-active { color: var(--text); background: var(--accent-soft); }

  /* Category bar */
  .catbar { border-top: 1px solid var(--border); background: rgba(0,0,0,0.2); }
  .catbar__inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-height: 44px;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .catbar__inner::-webkit-scrollbar { display: none; }
  .catbar__label {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-faint);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .catbar__nav { display: flex; gap: 0.35rem; }
  .catbar__link {
    padding: 0.3rem 0.65rem;
    border-radius: var(--radius);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--text-muted);
    text-decoration: none;
    white-space: nowrap;
  }
  .catbar__link:hover { color: var(--text); }
  .catbar__link.is-active {
    color: var(--text);
    box-shadow: inset 0 -2px 0 var(--accent);
    border-radius: 0;
  }

  /* Hamburger (mobile only) */
  .hamburger { display: none; cursor: pointer; padding: 0.5rem; }
  .hamburger span {
    display: block; width: 22px; height: 2px; margin: 4px 0;
    background: var(--text); transition: 0.2s;
  }

  .mobile-panel { display: none; border-top: 1px solid var(--border); }
  .mobile-panel .container { display: flex; flex-direction: column; padding-block: 0.5rem 1rem; }
  .mobile-panel__heading {
    font-family: var(--font-mono);
    font-size: 0.66rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--text-faint); padding: 0.9rem 0 0.4rem;
  }
  .mobile-panel__link {
    padding: 0.7rem 0.25rem;
    color: var(--text-muted); text-decoration: none; font-weight: 600;
    border-bottom: 1px solid var(--border);
  }
  .mobile-panel__link:hover, .mobile-panel__link.is-active { color: var(--text); }

  /* Mobile breakpoint */
  @media (max-width: 860px) {
    .util-nav, .catbar { display: none; }
    .hamburger { display: block; }
    .nav-toggle:checked ~ .mobile-panel { display: block; }
    .nav-toggle:checked ~ .bar .hamburger span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
    .nav-toggle:checked ~ .bar .hamburger span:nth-child(2) { opacity: 0; }
    .nav-toggle:checked ~ .bar .hamburger span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
  }
</style>
