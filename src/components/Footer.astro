---
import { SITE, NAV } from '../site.config';
const year = SITE.foundingYear;
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <a href="/" class="brand">
        <span class="brand__mark" aria-hidden="true">⚖</span>
        <span>{SITE.name}</span>
      </a>
      <p class="site-footer__tag">{SITE.tagline}</p>
    </div>

    <nav class="site-footer__nav" aria-label="Footer">
      <ul>
        {NAV.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
        <li><a href="/rss.xml">RSS</a></li>
      </ul>
    </nav>
  </div>

  <div class="container site-footer__legal">
    <p>© {year} {SITE.name}. All rights reserved.</p>
    <p class="site-footer__note">
      Reported from public records and primary sources. Stories are presented
      for informational purposes; individuals are presumed innocent unless
      convicted in a court of law.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 5rem;
    border-top: 1px solid var(--border);
    background: var(--bg-elevated);
    padding: 3rem 0 2rem;
  }
  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    justify-content: space-between;
    align-items: flex-start;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--text);
    text-decoration: none;
  }
  .brand__mark { color: var(--accent); }
  .site-footer__tag {
    margin-top: 0.6rem;
    color: var(--text-muted);
    max-width: 34ch;
    font-size: 0.95rem;
  }
  .site-footer__nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .site-footer__nav a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.95rem;
  }
  .site-footer__nav a:hover { color: var(--accent-hover); }
  .site-footer__legal {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    color: var(--text-faint);
    font-size: 0.82rem;
    display: grid;
    gap: 0.5rem;
  }
  .site-footer__note { max-width: 75ch; }
</style>
