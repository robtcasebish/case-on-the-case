---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, absoluteUrl } from '../site.config';
import { breadcrumbSchema } from '../lib/schema';

const updated = 'June 11, 2026';
const crumbs = breadcrumbSchema([
  { name: 'Home', url: SITE.url },
  { name: 'Terms of Use', url: absoluteUrl('/terms') },
]);
const pageSchema = {
  '@type': 'WebPage',
  name: `Terms of Use, ${SITE.name}`,
  url: absoluteUrl('/terms'),
  description: `The terms that govern use of ${SITE.name}, including conduct, accuracy, copyright, and liability.`,
};
---

<BaseLayout
  title="Terms of Use"
  description={`The terms that govern your use of ${SITE.name}: editorial purpose, conduct around sensitive cases, copyright, and disclaimers.`}
  path="/terms"
  schemaNodes={[pageSchema, crumbs]}
>
  <div class="container page prose legal">
    <p class="kicker">Legal</p>
    <h1>Terms of Use</h1>
    <p class="lede">
      Please read these terms. By using {SITE.name}, you agree to them.
    </p>

    <h2>Acceptance</h2>
    <p>
      By accessing or using this website, you agree to these Terms of Use. If you
      do not agree, please do not use the site.
    </p>

    <h2>Purpose of this site</h2>
    <p>
      {SITE.name} is an independent, non-commercial true-crime publication offered
      for informational and editorial purposes only. It carries no advertising and
      takes no funds from readers. Nothing here is legal advice,
      investigative advice, or professional guidance, and we are not affiliated
      with, and do not speak for, any law-enforcement agency, court, or government
      body.
    </p>

    <h2>These are real people and real harm</h2>
    <p>
      Our articles concern real victims, families, witnesses, suspects, and
      officials. You agree that you will not use this site, or information found
      here, to:
    </p>
    <ul>
      <li>harass, contact, threaten, dox, impersonate, stalk, or interfere with any victim, family member, witness, suspect, official, or other private individual;</li>
      <li>engage in vigilantism, or make or spread unsupported accusations against any person;</li>
      <li>break any law, or encourage others to do so.</li>
    </ul>
    <p>
      We do not publish content to enable any of the above, and such use is
      strictly prohibited.
    </p>

    <h2>Accuracy and corrections</h2>
    <p>
      Our articles are based on public records, official statements, court
      records, credible reporting, and cited sources where available. Facts can
      change as cases develop, and despite our care, errors can occur. We welcome
      corrections, see our <a href="/editorial-policy">Editorial Policy</a> or
      email <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
    </p>

    <h2>Presumption of innocence</h2>
    <p>
      Unless a person has been convicted in a court of law or has admitted
      responsibility, references to them on this site are not, and must not be
      treated as, proof of guilt. Everyone is presumed innocent unless and until
      proven otherwise.
    </p>

    <h2>Use of this site's content</h2>
    <p>
      We claim no copyright in the original writing and symbolic cover art created
      for {SITE.name}. To the extent any rights exist in that original material,
      they are dedicated to the public domain (CC0 1.0): you may copy, adapt, and
      republish it for any purpose, including commercially, without permission and
      without attribution. Credit and a link back are always appreciated, but
      never required.
    </p>
    <p>
      This dedication covers only our own original material. It does not cover
      third-party content: the sources, quotations, records, photographs, and
      embedded videos referenced here remain the property of their respective
      owners and are subject to their own terms. Names, facts, and events drawn
      from the public record are not owned by anyone.
    </p>

    <h2>External links</h2>
    <p>
      We link to third-party sources, records, and reporting for verification and
      further reading. We do not control and are not responsible for the content,
      accuracy, or practices of external sites.
    </p>

    <h2>"Further Viewing" videos</h2>
    <p>
      Where an article includes an embedded video, it is third-party supplementary
      content selected from a reputable source. Including a video is not an
      endorsement of every statement, opinion, or framing it contains, and the
      written, sourced article remains the authoritative version of our reporting.
    </p>

    <h2>Disclaimer and limitation of liability</h2>
    <p>
      This site is provided "as is," without warranties of any kind. To the
      fullest extent permitted by law, {SITE.name} and Rob T. Case are not liable
      for any loss or damage arising from your use of, or reliance on, the site or
      its content.
    </p>

    <h2>Changes to these terms</h2>
    <p>
      We may update these terms from time to time. Continued use of the site after
      a change means you accept the revised terms.
    </p>

    <h2>Contact</h2>
    <p>
      Questions about these terms? Email
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a> or see our
      <a href="/contact">Contact &amp; Requests</a> page.
    </p>

    <hr />
    <p class="legal__updated">Last updated: {updated}</p>
    <p class="fineprint">
      These terms are provided for transparency and are not legal advice.
    </p>
  </div>
</BaseLayout>

<style>
  .legal { max-width: 760px; padding-block: 2.5rem 1rem; }
  .legal h1 { margin-top: 0.5rem; }
  .legal .lede { font-family: var(--font-serif); font-size: 1.25rem; color: var(--text-muted); }
  .legal__updated { color: var(--text-muted); font-size: 0.9rem; font-weight: 600; }
  .fineprint { color: var(--text-faint); font-size: 0.88rem; }
</style>
