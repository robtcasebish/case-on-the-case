---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, absoluteUrl } from '../site.config';
import { breadcrumbSchema } from '../lib/schema';

const crumbs = breadcrumbSchema([
  { name: 'Home', url: SITE.url },
  { name: 'Submit a Case', url: absoluteUrl('/submit') },
]);
---

<BaseLayout
  title="Submit a Case"
  description={`Suggest a case for ${SITE.name} to cover — cold cases, local mysteries, missing persons, or a story that deserves another look.`}
  path="/submit"
  schemaNodes={[crumbs]}
>
  <section class="cathero">
    <div class="container">
      <p class="cathero__code">CONTACT</p>
      <h1>Submit a Case</h1>
      <p class="cathero__tagline">Every case starts with a tip.</p>
      <p class="cathero__blurb">
        Is there a case we should cover — a cold case, a local mystery, a missing
        person, or a story that never got the attention it deserved? Tell us about
        it. We read every submission, though we can't cover them all.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container submit">
      <form class="submit__form" action={`mailto:${SITE.email}`} method="post" enctype="text/plain" aria-label="Submit a case">
        <div class="field">
          <label for="case">Case name or subject</label>
          <input id="case" name="Case" type="text" placeholder="e.g. The disappearance of…" required />
        </div>
        <div class="field">
          <label for="where">Where &amp; when (if known)</label>
          <input id="where" name="Where_and_when" type="text" placeholder="City / state, year" />
        </div>
        <div class="field">
          <label for="details">Why this case?</label>
          <textarea id="details" name="Details" rows="6" placeholder="What happened, what's unresolved, and why it stayed with you. Links to coverage help." required></textarea>
        </div>
        <div class="field">
          <label for="email">Your email (optional)</label>
          <input id="email" name="Your_email" type="email" placeholder="So we can follow up" />
        </div>
        <button class="btn btn--accent" type="submit">Send submission</button>
        <p class="submit__note">
          This opens your email app addressed to <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
          Prefer to write directly? Email us anytime.
        </p>
      </form>

      <aside class="submit__aside">
        <h2>What helps most</h2>
        <ul>
          <li>The names, place, and year — even approximate.</li>
          <li>What's unresolved or what changed the case.</li>
          <li>Links to news coverage, records, or official pages.</li>
          <li>Why the case matters or stayed with you.</li>
        </ul>
        <h2>A note on care</h2>
        <p>
          We cover these stories with respect for victims and families, and we
          avoid gore, exploitation, and speculation presented as fact. If you're
          connected to a case, thank you for trusting us with it.
        </p>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .cathero {
    padding-block: clamp(2.5rem, 5vw, 4rem) 1.5rem;
    border-bottom: 1px solid var(--border);
    background:
      radial-gradient(120% 80% at 0% -20%, rgba(193,18,31,0.10) 0%, transparent 55%),
      var(--bg-elevated);
  }
  .cathero__code { font-family: var(--font-mono); font-size: 0.8rem; letter-spacing: 0.25em; color: var(--beige); margin-bottom: 0.6rem; }
  .cathero h1 { font-size: clamp(2.2rem, 1.6rem + 3vw, 3.4rem); }
  .cathero__tagline { margin-top: 0.7rem; font-family: var(--font-serif); font-style: italic; font-size: 1.3rem; color: var(--text-muted); }
  .cathero__blurb { margin-top: 1rem; color: var(--text-muted); max-width: 64ch; }

  .submit { display: grid; grid-template-columns: 1fr; gap: 2.5rem; }
  .submit__form { display: grid; gap: 1.1rem; max-width: 620px; }
  .field { display: grid; gap: 0.4rem; }
  .field label { font-size: 0.85rem; font-weight: 600; color: var(--text-muted); }
  .field input, .field textarea {
    width: 100%;
    background: var(--surface); color: var(--text);
    border: 1px solid var(--border-strong); border-radius: var(--radius);
    padding: 0.7rem 0.85rem; font: inherit; font-size: 0.95rem;
  }
  .field input:focus, .field textarea:focus { outline: 2px solid var(--focus); outline-offset: 1px; border-color: var(--accent); }
  .field textarea { resize: vertical; }
  .submit__note { font-size: 0.85rem; color: var(--text-faint); margin-top: 0.25rem; }
  .submit__note a { color: var(--accent-hover); }

  .submit__aside { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.5rem 1.6rem; align-self: start; }
  .submit__aside h2 { font-size: 1.15rem; margin-bottom: 0.7rem; }
  .submit__aside h2:nth-of-type(2) { margin-top: 1.5rem; }
  .submit__aside ul { padding-left: 1.1rem; display: grid; gap: 0.5rem; color: var(--text-muted); font-size: 0.93rem; }
  .submit__aside p { color: var(--text-muted); font-size: 0.93rem; }

  @media (min-width: 920px) {
    .submit { grid-template-columns: 1.4fr 1fr; gap: 3rem; }
  }
</style>
