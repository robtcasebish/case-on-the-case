---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StoryCard from '../../components/StoryCard.astro';
import { SITE, absoluteUrl } from '../../site.config';
import { breadcrumbSchema, itemListSchema } from '../../lib/schema';
import { readingTimeFromText, storySlug } from '../../lib/utils';

const stories = (await getCollection('stories', (s) => !s.data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const listSchema = itemListSchema(
  stories.map((s) => ({
    url: absoluteUrl(`/stories/${storySlug(s.id)}`),
    name: s.data.title,
  })),
  'All true crime stories',
);
const crumbs = breadcrumbSchema([
  { name: 'Home', url: SITE.url },
  { name: 'Stories', url: absoluteUrl('/stories') },
]);
---

<BaseLayout
  title="All Stories"
  description={`Every investigation from ${SITE.name} — cold cases, trials, forensics, and missing-persons reporting, fully sourced.`}
  path="/stories"
  schemaNodes={[listSchema, crumbs]}
>
  <div class="container page">
    <header class="page__head">
      <p class="kicker">The Archive</p>
      <h1>All Stories</h1>
      <p class="page__lede">Every case file we've published, newest first.</p>
    </header>

    {stories.length > 0 ? (
      <div class="grid grid--cards">
        {stories.map((s) => (
          <StoryCard
            href={`/stories/${storySlug(s.id)}`}
            title={s.data.title}
            description={s.data.description}
            category={s.data.category}
            pubDate={s.data.pubDate}
            location={s.data.location}
            caseStatus={s.data.caseStatus}
            readingTime={readingTimeFromText(s.body ?? '', s.data.readingTime)}
            cover={s.data.cover}
            coverAlt={s.data.coverAlt}
          />
        ))}
      </div>
    ) : (
      <p class="empty">No stories published yet — check back soon.</p>
    )}
  </div>
</BaseLayout>

<style>
  .page { padding-block: 2.5rem; }
  .page__head { margin-bottom: 2.5rem; }
  .page__head h1 { margin-top: 0.5rem; }
  .page__lede { margin-top: 0.75rem; color: var(--text-muted); font-size: 1.1rem; }
  .grid--cards {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }
  .empty { color: var(--text-muted); padding: 3rem 0; }
</style>
