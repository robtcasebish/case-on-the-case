---
import { getCollection, render } from 'astro:content';
import { getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE, absoluteUrl } from '../../site.config';
import {
  articleSchema,
  breadcrumbSchema,
  ORG_ID,
} from '../../lib/schema';
import { formatDate, isoDate, readingTimeFromText, storySlug } from '../../lib/utils';

export async function getStaticPaths() {
  const stories = await getCollection('stories', (s) => !s.data.draft);
  return stories.map((entry) => ({
    params: { slug: storySlug(entry.id) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data, body } = entry;
const { Content } = await render(entry);

const slug = storySlug(entry.id);
const path = `/stories/${slug}`;
const url = absoluteUrl(path);
const minutes = readingTimeFromText(body ?? '', data.readingTime);

// Resolve an absolute, optimized OG image if a cover is provided.
let ogImage: string | undefined;
if (data.cover) {
  const img = await getImage({ src: data.cover, width: 1200, height: 630, format: 'jpg' });
  ogImage = absoluteUrl(img.src);
}

const article = articleSchema({
  headline: data.title,
  description: data.description,
  url,
  datePublished: data.pubDate,
  dateModified: data.updatedDate,
  authorName: data.author,
  image: ogImage,
  section: data.category,
  keywords: data.tags,
  citations: data.sources,
  locationName: data.location,
});

const breadcrumbs = breadcrumbSchema([
  { name: 'Home', url: SITE.url },
  { name: 'Stories', url: absoluteUrl('/stories') },
  { name: data.title, url },
]);
---

<BaseLayout
  title={data.title}
  description={data.description}
  path={path}
  type="article"
  image={ogImage}
  imageAlt={data.coverAlt}
  publishedTime={data.pubDate.toISOString()}
  modifiedTime={(data.updatedDate ?? data.pubDate).toISOString()}
  author={data.author}
  section={data.category}
  tags={data.tags}
  schemaNodes={[article, breadcrumbs]}
>
  <article class="story container">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a> <span aria-hidden="true">/</span>
      <a href="/stories">Stories</a> <span aria-hidden="true">/</span>
      <span aria-current="page">{data.category}</span>
    </nav>

    <header class="story__head">
      <p class="kicker">{data.category}{data.caseStatus ? ` · ${data.caseStatus}` : ''}</p>
      <h1>{data.title}</h1>
      {data.dek && <p class="story__dek">{data.dek}</p>}

      <div class="story__byline">
        <span>By {data.author}</span>
        <span class="dot">·</span>
        <time datetime={isoDate(data.pubDate)}>{formatDate(data.pubDate)}</time>
        {data.updatedDate && (
          <>
            <span class="dot">·</span>
            <span>Updated <time datetime={isoDate(data.updatedDate)}>{formatDate(data.updatedDate)}</time></span>
          </>
        )}
        <span class="dot">·</span>
        <span>{minutes} min read</span>
      </div>

      {(data.location || data.caseYear) && (
        <dl class="casefile">
          {data.location && (<><dt>Location</dt><dd>{data.location}</dd></>)}
          {data.caseYear && (<><dt>Year</dt><dd>{data.caseYear}</dd></>)}
          {data.caseStatus && (<><dt>Status</dt><dd>{data.caseStatus}</dd></>)}
        </dl>
      )}
    </header>

    {data.cover && (
      <figure class="story__cover">
        <img src={data.cover.src} width={data.cover.width} height={data.cover.height} alt={data.coverAlt ?? ''} />
      </figure>
    )}

    <div class="story__body prose">
      <Content />
    </div>

    {data.sources.length > 0 && (
      <section class="sources" aria-labelledby="sources-h">
        <h2 id="sources-h">Sources</h2>
        <ol>
          {data.sources.map((s) => (
            <li>
              {s.url ? <a href={s.url} rel="nofollow noopener" target="_blank">{s.title}</a> : s.title}
              {s.publisher && <span class="sources__pub"> — {s.publisher}</span>}
            </li>
          ))}
        </ol>
      </section>
    )}

    {data.tags.length > 0 && (
      <nav class="tags" aria-label="Topics">
        {data.tags.map((t) => (
          <a class="tag" href={`/topics/${t.toLowerCase().replace(/\s+/g, '-')}`}>#{t}</a>
        ))}
      </nav>
    )}
  </article>
</BaseLayout>

<style>
  .story {
    max-width: 800px;
    padding-block: 2.5rem 1rem;
  }
  .crumbs {
    font-size: 0.82rem;
    color: var(--text-faint);
    margin-bottom: 1.5rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .crumbs a { color: var(--text-muted); text-decoration: none; }
  .crumbs a:hover { color: var(--accent-hover); }

  .story__head { margin-bottom: 2rem; }
  .story__head h1 { margin-top: 0.6rem; }
  .story__dek {
    margin-top: 1rem;
    font-size: 1.25rem;
    line-height: 1.5;
    color: var(--text-muted);
    font-family: var(--font-serif);
  }
  .story__byline {
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.88rem;
    color: var(--text-faint);
  }
  .dot { opacity: 0.5; }

  .casefile {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0.75rem 1.5rem;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--sepia);
    border-radius: var(--radius);
  }
  .casefile dt {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .casefile dd { margin: 0.15rem 0 0; font-weight: 600; }

  .story__cover {
    margin: 2rem 0;
  }
  .story__cover img {
    width: 100%;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    filter: saturate(0.9) contrast(1.04);
  }

  .sources {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .sources h2 { font-size: 1.3rem; }
  .sources ol {
    margin-top: 1rem;
    padding-left: 1.25rem;
    display: grid;
    gap: 0.6rem;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .sources__pub { color: var(--text-faint); }

  .tags {
    margin-top: 2.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag {
    font-size: 0.85rem;
    color: var(--text-muted);
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 0.3rem 0.7rem;
    border-radius: 100px;
    text-decoration: none;
  }
  .tag:hover { border-color: var(--accent); color: var(--accent-hover); }
</style>
