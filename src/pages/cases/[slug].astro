---
import { getCollection, render } from 'astro:content';
import { getImage, Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/Badge.astro';
import CaseCard from '../../components/CaseCard.astro';
import { SITE, AUTHOR, absoluteUrl, categorySlug, categoryByTitle } from '../../site.config';
import { articleSchema, breadcrumbSchema } from '../../lib/schema';
import { formatDate, isoDate, readingTimeFromText, caseSlug } from '../../lib/utils';
import fallbackImg from '../../assets/fallbacks/research-in-progress.png';

export async function getStaticPaths() {
  const all = await getCollection('cases', (c) => !c.data.draft);
  return all.map((entry) => ({
    params: { slug: caseSlug(entry.id) },
    props: { entry, all },
  }));
}

const { entry, all } = Astro.props;
const { data, body } = entry;
const { Content } = await render(entry);

const slug = caseSlug(entry.id);
const path = `/cases/${slug}`;
const url = absoluteUrl(path);
const minutes = readingTimeFromText(body ?? '', data.readingTime);
const primary = data.categories[0];

// Cover on every page where available; otherwise the shared in-progress art.
const cover = data.cover;
const heroImg = cover ?? fallbackImg;
const usingFallback = !cover;
const sourceCount = data.sources.length;
const articleType = data.placeholder ? 'Open file' : 'Feature';

let ogImage: string | undefined;
if (data.cover) {
  const img = await getImage({ src: data.cover, width: 1200, height: 630, format: 'jpg' });
  ogImage = absoluteUrl(img.src);
}

const article = articleSchema({
  headline: data.title,
  description: data.description,
  url,
  datePublished: data.pubDate,
  dateModified: data.updatedDate,
  authorName: data.author,
  image: ogImage,
  section: primary,
  keywords: [...data.categories, ...data.tags],
  citations: data.sources,
  locationName: data.location,
});
const breadcrumbs = breadcrumbSchema([
  { name: 'Home', url: SITE.url },
  { name: 'Cases', url: absoluteUrl('/cases') },
  { name: primary, url: absoluteUrl(`/${categorySlug(primary)}`) },
  { name: data.title, url },
]);

// Related: other cases sharing the primary category, completed first.
const related = all
  .filter((c) => caseSlug(c.id) !== slug && c.data.categories.includes(primary))
  .sort((a, b) => {
    const byDone = Number(a.data.placeholder) - Number(b.data.placeholder);
    return byDone !== 0 ? byDone : b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  })
  .slice(0, 3);

// What a research-in-progress file is being checked against.
const reviewing: [string, string][] = [
  ['Public records', 'Filings, official releases, and primary documents.'],
  ['Archived reporting', 'Contemporaneous newspaper and wire coverage.'],
  ['Timeline verification', 'Cross-checking dates, places, and sequence.'],
  ['Source review', 'Every claim confirmed against a credible source.'],
];
---

<BaseLayout
  title={data.title}
  description={data.description}
  path={path}
  type="article"
  image={ogImage}
  imageAlt={data.coverAlt}
  publishedTime={data.pubDate.toISOString()}
  modifiedTime={(data.updatedDate ?? data.pubDate).toISOString()}
  author={data.author}
  section={primary}
  tags={[...data.categories, ...data.tags]}
  schemaNodes={[article, breadcrumbs]}
>
  <article class="case">
    <div class="container">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a> <span aria-hidden="true">/</span>
        <a href="/cases">Cases</a> <span aria-hidden="true">/</span>
        <a href={`/${categorySlug(primary)}`}>{primary}</a>
      </nav>
    </div>

    <!-- Editorial split hero -->
    <header class="case-hero">
      <div class="container case-hero__grid">
        <div class="case-hero__text">
          <div class="case-hero__badges">
            {data.categories.map((c) => (
              <Badge label={c} variant="category" href={`/${categorySlug(c)}`} />
            ))}
            {data.caseStatus && <Badge label={data.caseStatus} variant="status" status={data.caseStatus} />}
          </div>
          <h1 class="case-hero__title">{data.title}</h1>
          {data.dek && <p class="case-hero__dek">{data.dek}</p>}
          <dl class="case-hero__meta">
            <div><dt>Type</dt><dd>{articleType}</dd></div>
            {data.caseYear && <div><dt>Year</dt><dd>{data.caseYear}</dd></div>}
            {data.location && <div><dt>Location</dt><dd>{data.location}</dd></div>}
            <div><dt>Read</dt><dd>{minutes} min</dd></div>
          </dl>
          {!data.placeholder && (
            <p class="case-hero__byline">By <a href={AUTHOR.url}>{data.author}</a></p>
          )}
        </div>
        <figure class="case-hero__media">
          <Image
            src={heroImg}
            alt={cover ? (data.coverAlt ?? '') : ''}
            widths={[600, 900, 1300]}
            sizes="(max-width: 900px) 100vw, 540px"
            loading="eager"
            fetchpriority="high"
            class:list={['case-hero__img', { 'is-fallback': usingFallback }]}
          />
          <span class="case-hero__scrim" aria-hidden="true"></span>
        </figure>
      </div>
    </header>

    <div class="container case-body">
      <aside class="caserail" aria-label="Case file">
        <p class="caserail__tab">Case File</p>
        <dl>
          {data.caseStatus && (<div><dt>Status</dt><dd class:list={[`s-${data.caseStatus.toLowerCase()}`]}>{data.caseStatus}</dd></div>)}
          {data.caseYear && (<div><dt>Year</dt><dd>{data.caseYear}</dd></div>)}
          {data.location && (<div><dt>Location</dt><dd>{data.location}</dd></div>)}
          <div><dt>Filed under</dt><dd>{data.categories.join(', ')}</dd></div>
          <div><dt>Sources</dt><dd>{data.placeholder ? 'Under review' : (sourceCount > 0 ? `${sourceCount} linked` : 'See below')}</dd></div>
        </dl>
        <a class="caserail__back" href="/cases"><span aria-hidden="true">←</span> Back to the archive</a>
      </aside>

      <div class="case-main">
        {data.oneSentence && (
          <section class="onesentence" aria-label="The case in one sentence">
            <p class="onesentence__label">The Case in One Sentence</p>
            <p class="onesentence__text">{data.oneSentence}</p>
          </section>
        )}

        {data.placeholder ? (
          <section class="rip" aria-label="Research in progress">
            <p class="rip__status"><span class="rip__dot" aria-hidden="true"></span> Research in progress</p>
            <p class="rip__lead">This case file is being assembled from public records, archived reporting, and verified source material. A full narrative will be published once the timeline and sourcing are ready.</p>
            <p class="rip__subhead">What we're reviewing</p>
            <ul class="rip__list">
              {reviewing.map(([t, d]) => (
                <li>
                  <span class="rip__item-title">{t}</span>
                  <span class="rip__item-desc">{d}</span>
                </li>
              ))}
            </ul>
            <div class="rip__cta">
              <a class="btn" href="/cases">Browse the archive</a>
              <a class="btn btn--accent" href="/cases/db-cooper">Read a completed case</a>
            </div>
          </section>
        ) : (
          <>
            <div class="prose case-prose">
              <Content />
            </div>

            <section class="sources" aria-labelledby="sources-h">
              <p class="sources__kicker">Source discipline</p>
              <h2 id="sources-h">Sources &amp; Further Reading</h2>
              {data.sources.length > 0 ? (
                <ol class="sources__list">
                  {data.sources.map((s) => (
                    <li>
                      {s.url
                        ? <a href={s.url} rel="nofollow noopener" target="_blank">{s.title}</a>
                        : <span class="sources__title">{s.title}</span>}
                      {s.publisher && <span class="sources__pub">{s.publisher}</span>}
                    </li>
                  ))}
                </ol>
              ) : (
                <p class="sources__empty">Sources are being finalised for this article.</p>
              )}
            </section>

            {data.video && (
              <section class="furtherviewing" aria-label="Further viewing">
                <p class="sources__kicker">Further Viewing</p>
                <h2>Further Viewing</h2>
                <div class="video-embed">
                  <iframe
                    src={`https://www.youtube-nocookie.com/embed/${data.video.youtubeId}?rel=0`}
                    title={`Further viewing: ${data.video.title} (${data.video.source})`}
                    loading="lazy"
                    allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    referrerpolicy="strict-origin-when-cross-origin"
                    allowfullscreen
                  ></iframe>
                </div>
                <p class="furtherviewing__cite">
                  <strong>{data.video.title}</strong>
                  <span class="furtherviewing__source"> · {data.video.source}</span>
                </p>
                {data.video.note && <p class="furtherviewing__note">{data.video.note}</p>}
                <p class="furtherviewing__disclaimer">Selected as supplementary viewing from an approved source. Case on the Case does not control third-party video content, and videos are supplementary, they do not replace the written sources above.</p>
              </section>
            )}
          </>
        )}
      </div>
    </div>

    {related.length > 0 && (
      <section class="related section--alt">
        <div class="container">
          <div class="section__head">
            <div>
              <p class="eyebrow">Keep reading</p>
              <h2>More from {primary}</h2>
            </div>
            <a class="section__more" href={`/${categorySlug(primary)}`}>View all →</a>
          </div>
          <div class="grid grid--cards">
            {related.map((c) => (
              <CaseCard
                href={`/cases/${caseSlug(c.id)}`}
                title={c.data.title}
                description={c.data.description}
                category={c.data.categories[0]}
                status={c.data.caseStatus}
                location={c.data.location}
                year={c.data.caseYear}
                readingTime={readingTimeFromText(c.body ?? '', c.data.readingTime)}
                cover={c.data.cover}
                coverAlt={c.data.coverAlt}
                placeholder={c.data.placeholder}
                fileCode={categoryByTitle(c.data.categories[0])?.code}
              />
            ))}
          </div>
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .case { padding-bottom: 1rem; }
  .crumbs {
    font-size: 0.8rem; color: var(--text-faint);
    padding-top: 1.6rem; display: flex; gap: 0.5rem; flex-wrap: wrap;
  }
  .crumbs a { color: var(--text-muted); text-decoration: none; }
  .crumbs a:hover { color: var(--accent-hover); }

  /* ---- Editorial split hero ----------------------------------------------- */
  .case-hero { padding-block: clamp(1.5rem, 4vw, 2.75rem) clamp(1.75rem, 4vw, 3rem); }
  .case-hero__grid { display: grid; gap: clamp(1.5rem, 4vw, 2.75rem); align-items: center; }
  .case-hero__badges { display: flex; gap: 0.45rem; flex-wrap: wrap; margin-bottom: 1.1rem; }
  .case-hero__title {
    font-size: clamp(2.1rem, 1.5rem + 3vw, 3.6rem);
    line-height: 1.04; letter-spacing: -0.02em;
  }
  .case-hero__dek {
    margin-top: 1.1rem; max-width: 46ch;
    font-family: var(--font-serif);
    font-size: clamp(1.15rem, 1rem + 0.6vw, 1.45rem);
    line-height: 1.5; color: var(--text-muted);
  }
  .case-hero__meta {
    margin-top: 1.5rem; display: flex; flex-wrap: wrap; gap: 0 1.6rem;
    border-top: 1px solid var(--border); padding-top: 1.1rem;
  }
  .case-hero__meta div { display: flex; flex-direction: column; gap: 0.2rem; }
  .case-hero__meta dt {
    font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--text-faint);
  }
  .case-hero__meta dd { margin: 0; font-weight: 600; font-size: 0.95rem; color: var(--text); }
  .case-hero__byline { margin-top: 1rem; font-size: 0.9rem; color: var(--text-muted); }
  .case-hero__byline a { color: var(--text-muted); text-decoration: none; border-bottom: 1px solid var(--border); }
  .case-hero__byline a:hover { color: var(--accent-hover); }

  .case-hero__media {
    position: relative; border-radius: var(--radius-lg); overflow: hidden;
    border: 1px solid var(--border-strong); box-shadow: 0 18px 50px rgba(0,0,0,0.5);
    aspect-ratio: 3 / 2;
  }
  .case-hero__img {
    width: 100%; height: 100%; object-fit: cover; object-position: center;
    filter: saturate(0.88) contrast(1.05) brightness(0.92);
  }
  .case-hero__img.is-fallback { filter: saturate(0.55) contrast(1.04) brightness(0.7); }
  .case-hero__scrim {
    position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(180deg, transparent 55%, rgba(8,8,10,0.5) 100%);
  }

  @media (min-width: 880px) {
    .case-hero__grid { grid-template-columns: 1.05fr 0.95fr; }
    .case-hero__media { aspect-ratio: 4 / 3; }
  }

  /* ---- Body: case-file rail + readable column ----------------------------- */
  .case-body {
    display: grid; grid-template-columns: 1fr; gap: 2.25rem;
    padding-block: clamp(1.5rem, 4vw, 2.5rem) 1.5rem;
  }
  .case-main { min-width: 0; max-width: 72ch; }

  .caserail {
    align-self: start;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.015), transparent 40%),
      var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--sepia);
    border-radius: var(--radius);
    padding: 1.1rem 1.25rem 1rem;
  }
  .caserail__tab {
    font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--beige); margin-bottom: 0.85rem;
  }
  .caserail dl { display: grid; gap: 0.8rem; margin: 0; }
  .caserail dt {
    font-size: 0.64rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--text-faint); margin-bottom: 0.15rem;
  }
  .caserail dd { margin: 0; font-weight: 600; font-size: 0.95rem; }
  .caserail dd.s-solved { color: #7bdca0; }
  .caserail dd.s-unsolved, .caserail dd.s-cold { color: var(--sepia); }
  .caserail dd.s-ongoing { color: var(--accent-hover); }
  .caserail__back {
    display: inline-block; margin-top: 1.1rem; padding-top: 0.9rem;
    border-top: 1px solid var(--border);
    font-size: 0.82rem; font-weight: 600; color: var(--text-muted);
    text-decoration: none;
  }
  .caserail__back:hover { color: var(--accent-hover); }

  @media (min-width: 1000px) {
    .case-body {
      grid-template-columns: 232px minmax(0, 72ch);
      justify-content: center; gap: 3.25rem;
    }
    .caserail { position: sticky; top: 120px; }
  }

  /* ---- The case in one sentence ------------------------------------------- */
  .onesentence {
    border-left: 3px solid var(--accent);
    padding: 0.3rem 0 0.4rem 1.5rem; margin-bottom: 2.25rem;
  }
  .onesentence__label {
    font-family: var(--font-sans); font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent-hover);
    margin-bottom: 0.55rem;
  }
  .onesentence__text {
    font-family: var(--font-serif); font-size: clamp(1.3rem, 1.1rem + 0.9vw, 1.6rem);
    line-height: 1.42; color: var(--text);
  }

  /* ---- Longform body, with section rhythm --------------------------------- */
  .case-prose { font-size: 1.075rem; line-height: 1.8; color: #d9d5cd; }
  .case-prose :global(p) { margin-top: 1.15em; }
  .case-prose :global(h2) {
    position: relative;
    margin-top: 2.75rem; padding-top: 1.4rem;
    border-top: 1px solid var(--border);
    font-size: clamp(1.35rem, 1.15rem + 0.9vw, 1.75rem);
  }
  .case-prose :global(h2)::before {
    content: ''; position: absolute; top: -1px; left: 0;
    width: 2.25rem; height: 2px; background: var(--accent);
  }
  .case-prose :global(h2:first-child) { margin-top: 0; padding-top: 0; border-top: 0; }
  .case-prose :global(h2:first-child)::before { display: none; }
  .case-prose :global(h3) { margin-top: 1.9rem; }
  .case-prose :global(a) { text-decoration: underline; text-underline-offset: 3px; }
  .case-prose :global(strong) { color: var(--text); }

  /* ---- Research in progress, integrated ----------------------------------- */
  .rip {
    background:
      radial-gradient(120% 100% at 0% 0%, rgba(184,173,151,0.07), transparent 55%),
      var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: clamp(1.5rem, 4vw, 2.4rem);
  }
  .rip__status {
    display: inline-flex; align-items: center; gap: 0.55rem;
    font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--beige);
  }
  .rip__dot {
    width: 7px; height: 7px; border-radius: 50%; background: var(--sepia);
    box-shadow: 0 0 0 3px rgba(201,169,106,0.15);
  }
  .rip__lead {
    margin-top: 1rem; max-width: 56ch;
    font-family: var(--font-serif); font-size: 1.2rem; line-height: 1.55; color: var(--text);
  }
  .rip__subhead {
    margin-top: 1.9rem; margin-bottom: 0.9rem;
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--text-faint);
  }
  .rip__list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.75rem; }
  .rip__list li {
    display: grid; gap: 0.15rem;
    padding: 0.85rem 1rem; background: var(--bg-elevated);
    border: 1px solid var(--border); border-radius: var(--radius);
  }
  .rip__item-title { font-weight: 600; font-size: 0.95rem; color: var(--text); }
  .rip__item-desc { font-size: 0.88rem; color: var(--text-muted); }
  .rip__cta { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.75rem; }
  @media (min-width: 620px) { .rip__list { grid-template-columns: 1fr 1fr; } }

  /* ---- Sources ------------------------------------------------------------ */
  .sources { margin-top: 3rem; padding-top: 1.6rem; border-top: 2px solid var(--border-strong); }
  .sources__kicker {
    font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--beige); margin-bottom: 0.5rem;
  }
  .sources h2 { font-size: 1.4rem; }
  .sources__list {
    margin-top: 1.2rem; padding: 0; list-style: none;
    display: grid; gap: 0;
  }
  .sources__list li {
    display: flex; flex-direction: column; gap: 0.2rem;
    padding: 0.85rem 0; border-bottom: 1px solid var(--border);
  }
  .sources__list li:first-child { border-top: 1px solid var(--border); }
  .sources__list a, .sources__title {
    font-weight: 600; font-size: 1rem; color: var(--text);
    text-decoration: none;
  }
  .sources__list a { text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: 3px; }
  .sources__list a:hover { color: var(--accent-hover); }
  .sources__pub { font-size: 0.85rem; color: var(--text-faint); }
  .sources__empty { margin-top: 0.9rem; color: var(--text-faint); font-style: italic; }

  /* ---- Further viewing (approved-channel embed) --------------------------- */
  .furtherviewing { margin-top: 2.75rem; padding-top: 1.6rem; border-top: 1px solid var(--border); }
  .furtherviewing h2 { font-size: 1.4rem; }
  .video-embed {
    position: relative; aspect-ratio: 16 / 9; margin: 1.2rem 0 0.9rem;
    border-radius: var(--radius-lg); overflow: hidden;
    border: 1px solid var(--border-strong); background: #000;
  }
  .video-embed iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
  .furtherviewing__cite { font-size: 0.98rem; color: var(--text); }
  .furtherviewing__source { color: var(--text-muted); }
  .furtherviewing__note { margin-top: 0.45rem; color: var(--text-muted); font-size: 0.95rem; line-height: 1.6; }
  .furtherviewing__disclaimer { margin-top: 0.85rem; color: var(--text-faint); font-size: 0.82rem; font-style: italic; line-height: 1.55; }

  /* ---- Related ------------------------------------------------------------ */
  .related { margin-top: 3rem; padding-block: clamp(2rem, 5vw, 3.25rem); }
</style>
