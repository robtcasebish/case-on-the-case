---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseCard from '../../components/CaseCard.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import { SITE, CATEGORIES, absoluteUrl, categoryByTitle } from '../../site.config';
import { breadcrumbSchema, itemListSchema } from '../../lib/schema';
import { readingTimeFromText, caseSlug } from '../../lib/utils';

const all = (await getCollection('cases', (c) => !c.data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const rt = (c) => readingTimeFromText(c.body ?? '', c.data.readingTime);
const code = (c) => categoryByTitle(c.data.categories[0])?.code;
const counts = Object.fromEntries(
  CATEGORIES.map((c) => [c.title, all.filter((s) => s.data.categories.includes(c.title)).length]),
);

// Completed work leads; in-progress files sit in a quieter section below.
const reported = all.filter((c) => !c.data.placeholder);
const openFiles = all.filter((c) => c.data.placeholder);

const cardProps = (s) => ({
  href: `/cases/${caseSlug(s.id)}`,
  title: s.data.title,
  description: s.data.description,
  category: s.data.categories[0],
  status: s.data.caseStatus,
  location: s.data.location,
  year: s.data.caseYear,
  readingTime: rt(s),
  cover: s.data.cover,
  coverAlt: s.data.coverAlt,
  placeholder: s.data.placeholder,
  fileCode: code(s),
});

const listSchema = itemListSchema(
  all.map((s) => ({ url: absoluteUrl(`/cases/${caseSlug(s.id)}`), name: s.data.title })),
  'All cases',
);
const crumbs = breadcrumbSchema([
  { name: 'Home', url: SITE.url },
  { name: 'Cases', url: absoluteUrl('/cases') },
]);
---

<BaseLayout
  title="All Cases"
  description={`The complete Case on the Case archive, solved cold cases, famous crimes, missing persons, forensic evidence, citizen sleuthing, and the cases that changed the law.`}
  path="/cases"
  schemaNodes={[listSchema, crumbs]}
>
  <div class="container page">
    <header class="page__head">
      <p class="eyebrow">The complete archive</p>
      <h1>Every Case on File</h1>
      <p class="page__lede">{reported.length} cases, every one reported in full and sourced from the public record. Browse the newest below, or start with a section.</p>
    </header>
  </div>

  {reported.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section__head">
          <div>
            <p class="eyebrow">Reported in full</p>
            <h2>Finished Cases</h2>
          </div>
          <span class="section__more">{reported.length} {reported.length === 1 ? 'file' : 'files'}</span>
        </div>
        <div class="grid grid--cards">
          {reported.map((s) => <CaseCard {...cardProps(s)} />)}
        </div>
      </div>
    </section>
  )}

  <section class="section section--alt">
    <div class="container">
      <div class="section__head">
        <div>
          <p class="eyebrow">Browse the index</p>
          <h2>The Index</h2>
        </div>
        <span class="section__more">Six sections</span>
      </div>
      <div class="grid grid--cats">
        {CATEGORIES.map((c) => (
          <CategoryCard title={c.title} slug={c.slug} blurb={c.blurb} code={c.code} cta={c.cta} count={counts[c.title]} />
        ))}
      </div>
    </div>
  </section>

  {openFiles.length > 0 && (
    <section class="section openfiles">
      <div class="container">
        <div class="section__head">
          <div>
            <p class="eyebrow">Still under review</p>
            <h2>Open Files</h2>
          </div>
          <span class="section__more">{openFiles.length} {openFiles.length === 1 ? 'file' : 'files'}</span>
        </div>
        <p class="section__intro">Case files we're assembling from public records and archived reporting. Each opens to what we're verifying before publication.</p>
        <div class="grid grid--cards">
          {openFiles.map((s) => <CaseCard {...cardProps(s)} />)}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
