---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CaseCard from '../components/CaseCard.astro';
import { SITE, CATEGORIES, absoluteUrl, categoryByTitle } from '../site.config';
import { breadcrumbSchema, itemListSchema, faqSchema } from '../lib/schema';
import { readingTimeFromText, caseSlug } from '../lib/utils';

import catSolved from '../assets/categories/solved-cold-cases.png';
import catFamous from '../assets/categories/famous-cases.png';
import catMissing from '../assets/categories/missing-vanished.png';
import catEvidence from '../assets/categories/evidence-room.png';
import catCitizen from '../assets/categories/citizen-sleuths.png';
import catLaw from '../assets/categories/changed-the-law.png';

const CATEGORY_IMAGES: Record<string, ImageMetadata> = {
  'solved-cold-cases': catSolved,
  'famous-cases': catFamous,
  'missing-and-vanished': catMissing,
  'the-evidence-room': catEvidence,
  'citizen-sleuths': catCitizen,
  'cases-that-changed-the-law': catLaw,
};

export async function getStaticPaths() {
  const all = await getCollection('cases', (c) => !c.data.draft);
  return CATEGORIES.map((cat) => {
    const items = all
      .filter((s) => s.data.categories.includes(cat.title))
      .sort((a, b) => {
        // Completed, fully-reported cases first; then newest.
        const p = Number(a.data.placeholder) - Number(b.data.placeholder);
        return p !== 0 ? p : b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
      });
    return { params: { category: cat.slug }, props: { cat, items } };
  });
}

const { cat, items } = Astro.props;
const path = `/${cat.slug}`;
const reported = items.filter((i) => !i.data.placeholder).length;
const catImg = CATEGORY_IMAGES[cat.slug];

// Short, factual reader Q&A per section (also emitted as FAQPage schema).
const FURTHER_VIEWING_FAQ = {
  q: 'Why do some articles include a Further Viewing video and others do not?',
  a: 'Where a credible documentary or news segment from a trusted source genuinely adds context, we embed one as optional further viewing. When no suitable, respectful source exists, we leave the article without a video rather than add one for its own sake.',
};
const CATEGORY_FAQ: Record<string, { q: string; a: string }[]> = {
  'solved-cold-cases': [
    { q: 'What is a solved cold case?', a: 'A cold case is a crime that went unsolved for years, often decades, after the original investigation stalled. We file a case here once it has been resolved, usually through a conviction, a guilty plea, or a confirmed identification, frequently with the help of modern DNA and forensic genetic genealogy.' },
    { q: 'How does Case on the Case decide a cold case is solved?', a: 'We rely on the public record: convictions, guilty pleas, official law-enforcement determinations, or confirmed identifications reported by credible sources. Where a case is only partly resolved, such as an identity restored but a killing still open, we say so plainly.' },
  ],
  'famous-cases': [
    { q: "What makes a case 'famous' here?", a: 'Cases that entered the wider culture and are recognized well beyond the communities they touched. We revisit them past the headlines, focused on the documented record rather than the myth.' },
    FURTHER_VIEWING_FAQ,
  ],
  'missing-and-vanished': [
    { q: 'How does Case on the Case handle unsolved disappearances?', a: 'We report what the public record establishes and clearly mark what remains unknown. We lead with the missing person, avoid speculation, and preserve the presumption of innocence for anyone who has not been convicted.' },
    FURTHER_VIEWING_FAQ,
  ],
  'the-evidence-room': [
    { q: 'What makes a case part of The Evidence Room?', a: 'These are cases where a specific piece of evidence, a fiber, a fingerprint, a preserved DNA sample, or a digital trail, became the turning point. The focus is on the forensic work and on what the evidence could, and could not, prove.' },
    FURTHER_VIEWING_FAQ,
  ],
  'citizen-sleuths': [
    { q: 'What does Case on the Case mean by Citizen Sleuths?', a: 'Cases where members of the public, online communities, or amateur investigators played a meaningful role, whether by identifying a suspect, restoring a victim\'s name, or keeping a cold case visible. We also note the real limits and risks of public investigation.' },
    FURTHER_VIEWING_FAQ,
  ],
  'cases-that-changed-the-law': [
    { q: 'What kinds of cases changed the law?', a: 'Cases whose aftermath produced new legislation or lasting policy, from sex-offender registries and missing-children systems to consumer-safety rules and hate-crime statutes. We trace the line from the case to the law it shaped.' },
    FURTHER_VIEWING_FAQ,
  ],
};
const faqs = CATEGORY_FAQ[cat.slug] ?? [];

const listSchema = itemListSchema(
  items.map((s) => ({ url: absoluteUrl(`/cases/${caseSlug(s.id)}`), name: s.data.title })),
  cat.title,
);
const crumbs = breadcrumbSchema([
  { name: 'Home', url: SITE.url },
  { name: 'Cases', url: absoluteUrl('/cases') },
  { name: cat.title, url: absoluteUrl(path) },
]);
const schemaNodes = faqs.length ? [listSchema, crumbs, faqSchema(faqs)] : [listSchema, crumbs];
---

<BaseLayout
  title={cat.title}
  description={`${cat.blurb}, true crime case files from ${SITE.name}.`}
  path={path}
  schemaNodes={schemaNodes}
>
  <section class:list={['cathero', { 'has-image': catImg }]}>
    {catImg && (
      <div class="cathero__bg" aria-hidden="true">
        <Image src={catImg} alt="" widths={[800, 1280, 1600]} sizes="100vw" loading="eager" fetchpriority="high" class="cathero__bgimg" />
      </div>
    )}
    <div class="container cathero__inner">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a> <span aria-hidden="true">/</span>
        <a href="/cases">Cases</a> <span aria-hidden="true">/</span>
        <span aria-current="page">{cat.title}</span>
      </nav>
      <p class="cathero__file">Section {cat.code} · The Index</p>
      <h1>{cat.title}</h1>
      <p class="cathero__tagline">{cat.tagline}</p>
      <p class="cathero__blurb">{cat.blurb}</p>
      <p class="cathero__count">
        {reported} {reported === 1 ? 'case' : 'cases'} reported in full{items.length > reported ? `, ${items.length - reported} in progress` : ''}
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {items.length > 0 ? (
        <div class="grid grid--cards">
          {items.map((s) => (
            <CaseCard
              href={`/cases/${caseSlug(s.id)}`}
              title={s.data.title}
              description={s.data.description}
              category={s.data.categories[0]}
              status={s.data.caseStatus}
              location={s.data.location}
              year={s.data.caseYear}
              readingTime={readingTimeFromText(s.body ?? '', s.data.readingTime)}
              cover={s.data.cover}
              coverAlt={s.data.coverAlt}
              placeholder={s.data.placeholder}
              fileCode={categoryByTitle(s.data.categories[0])?.code}
            />
          ))}
        </div>
      ) : (
        <p class="empty">No cases filed here yet, new stories are added regularly.</p>
      )}
    </div>
  </section>

  {faqs.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <div class="section__head">
          <div>
            <p class="eyebrow">About this section</p>
            <h2>Questions, answered</h2>
          </div>
        </div>
        <dl class="catfaq">
          {faqs.map((f) => (
            <div class="catfaq__item">
              <dt>{f.q}</dt>
              <dd>{f.a}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .cathero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding-block: clamp(2.5rem, 5vw, 4rem) 1.5rem;
    border-bottom: 1px solid var(--border);
    background:
      radial-gradient(110% 80% at 0% -20%, rgba(193,18,31,0.09) 0%, transparent 55%),
      var(--bg-elevated);
  }
  /* Cinematic category cover behind a left-weighted dark gradient. */
  .cathero.has-image { padding-block: clamp(3.25rem, 7vw, 5.5rem) clamp(1.75rem, 3vw, 2.25rem); }
  .cathero__bg { position: absolute; inset: 0; z-index: 0; }
  .cathero__bgimg {
    width: 100%; height: 100%; object-fit: cover; object-position: center;
    filter: saturate(0.8) contrast(1.05) brightness(0.78);
  }
  .cathero.has-image::after {
    content: ''; position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(90deg, rgba(11,11,13,0.95) 0%, rgba(11,11,13,0.82) 45%, rgba(11,11,13,0.5) 100%),
      linear-gradient(180deg, rgba(11,11,13,0.2) 0%, rgba(11,11,13,0.72) 100%);
  }
  .cathero__inner { position: relative; z-index: 2; }
  .crumbs { font-size: 0.8rem; color: var(--text-faint); margin-bottom: 1.4rem; display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .crumbs a { color: var(--text-muted); text-decoration: none; }
  .crumbs a:hover { color: var(--accent-hover); }
  .cathero__file {
    font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--beige); margin-bottom: 0.7rem;
  }
  .cathero h1 { font-size: clamp(2.2rem, 1.6rem + 3vw, 3.6rem); }
  .cathero__tagline { margin-top: 0.75rem; font-family: var(--font-serif); font-style: italic; font-size: 1.3rem; color: var(--text-muted); }
  .cathero__blurb { margin-top: 1rem; color: var(--text-muted); max-width: 64ch; }
  .cathero__count { margin-top: 1.1rem; font-size: 0.82rem; color: var(--text-faint); }

  /* Section Q&A (also emitted as FAQPage schema) */
  .catfaq { display: grid; gap: 1.4rem; max-width: 70ch; margin: 0; }
  .catfaq__item dt {
    font-family: var(--font-serif); font-weight: 700;
    font-size: 1.12rem; color: var(--text); margin-bottom: 0.4rem;
  }
  .catfaq__item dd { margin: 0; color: var(--text-muted); line-height: 1.65; }
</style>
