---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, AUTHOR, absoluteUrl } from '../site.config';
import { breadcrumbSchema } from '../lib/schema';

const crumbs = breadcrumbSchema([
  { name: 'Home', url: SITE.url },
  { name: 'About', url: absoluteUrl('/about') },
]);
const aboutSchema = {
  '@type': 'AboutPage',
  name: `About ${SITE.name}`,
  url: absoluteUrl('/about'),
  description: `Editorial standards, sourcing methodology, and corrections policy for ${SITE.name}.`,
  mainEntity: { '@type': 'Organization', name: SITE.publisher, url: SITE.url, description: AUTHOR.bio },
};
---

<BaseLayout
  title="About & Editorial Standards"
  description={`How ${SITE.name} researches, verifies, and tells true crime stories, our methodology, ethics, and corrections policy.`}
  path="/about"
  schemaNodes={[aboutSchema, crumbs]}
>
  <div class="container page prose about">
    <p class="kicker">About</p>
    <h1>About Case on the Case</h1>
    <p class="lede">{SITE.tagline}</p>

    <p>
      <strong>Case on the Case</strong> began as a place to share short true crime
      stories, cold cases, solved mysteries, famous cases, missing persons,
      forensic breakthroughs, and the work of citizen sleuths. This site turns
      those stories into something you can read, browse, and follow: a true crime
      publication built to be investigative, cinematic, and respectful.
    </p>

    <h2>How we report</h2>
    <p>
      We revisit cases with curiosity and care. Every story is built from the
      public record and contemporaneous reporting, and every claim of fact is
      traceable to a source. We prioritize primary sources, court filings, police
      reports, official records, and verified journalism, and each case ends with
      a <strong>Sources &amp; Further Reading</strong> list.
    </p>

    <h2>Our standards</h2>
    <ul>
      <li><strong>Accuracy first.</strong> Where a case is unresolved or a person hasn't been convicted, we say so plainly and label case status.</li>
      <li><strong>Respect for victims.</strong> We avoid gore, exploitation, and shock imagery. These were real people, and we write like it.</li>
      <li><strong>No speculation as fact.</strong> Theories are labeled as theories. Presumption of innocence is the rule.</li>
    </ul>

    <h2>Corrections</h2>
    <p>
      If we get something wrong, we fix it and note the change. To report an error
      or share information about a case, email
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a>, or
      <a href="/submit">submit a case</a> for future coverage.
    </p>

    <h2>Who writes these stories</h2>
    <p>{AUTHOR.bio}</p>

    <hr />
    <p class="fineprint">
      {SITE.name} is an independent publication. Stories are presented for
      informational and educational purposes and do not constitute legal advice.
    </p>
  </div>
</BaseLayout>

<style>
  .about { max-width: 760px; padding-block: 2.5rem 1rem; }
  .about h1 { margin-top: 0.5rem; }
  .lede { font-family: var(--font-serif); font-size: 1.3rem; color: var(--text-muted); }
  .fineprint { color: var(--text-faint); font-size: 0.88rem; }
</style>
